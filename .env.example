# Reflection text (primary)
ANTHROPIC_API_KEY=

# Comic image fallback
OPENAI_API_KEY=

# Comic image primary (Imagen 4 → 3)
GEMINI_API_KEY=

# --- Pipeline flags (enable one piece at a time for E2E validation) ---
SEEN_ENABLE_TEXT=true
SEEN_ENABLE_VOICE=false
SEEN_ENABLE_IMAGE=false

# Logging: DEBUG, INFO, WARNING, ERROR
SEEN_LOG_LEVEL=DEBUG

# --- Text models (reflection) ---
TEXT_MODEL_PRIMARY=claude-sonnet-4-20250514
TEXT_MODEL_SECONDARY=

# --- Voice providers/models (TTS) ---
VOICE_PROVIDER_PRIMARY=openai
VOICE_PROVIDER_SECONDARY=voicebox
VOICE_MODEL_PRIMARY=gpt-4o-mini-tts
VOICE_MODEL_SECONDARY=tts-1

# --- Image providers/models (comic) ---
IMAGE_PROVIDER_PRIMARY=gemini
IMAGE_PROVIDER_SECONDARY=openai
IMAGE_MODEL_PRIMARY=imagen-4.0-generate-001
IMAGE_MODEL_SECONDARY=dall-e-3
IMAGE_GEMINI_FALLBACK_MODELS=imagen-4.0-fast-generate-001,imagen-3.0-generate-002

# TTS fallback when OpenAI fails (native Voicebox API, not OpenAI-compatible)
VOICEBOX_BASE_URL=http://127.0.0.1:17493
# Default Voicebox profile when narrator has no voicebox_profile set
VOICEBOX_PROFILE_ID=
